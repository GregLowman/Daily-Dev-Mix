<!-- Beginning of Script Code and Functions -->

<script>
  let pollHandle = null;
  let uiTickHandle = null;
  let isEndingSession = false;
  let activeSession = null;
  let activeSessionSyncedAt = 0;
  let activeTrackSyncedAt = 0;

  const sessionMessage = document.getElementById('sessionMessage');
  const endBtn = document.getElementById('endBtn');
  const endBtnLabel = document.getElementById('endBtnLabel');

  function showMessage(message, type) {
    if (!message) {
      sessionMessage.textContent = '';
      sessionMessage.className = 'session-message';
      return;
    }

    sessionMessage.textContent = message;
    sessionMessage.className = 'session-message visible ' + (type || 'info');
  }

  function formatTrackDuration(ms) {
    const totalSeconds = Math.max(0, Math.floor((ms || 0) / 1000));
    const minutes = Math.floor(totalSeconds / 60);
    const seconds = String(totalSeconds % 60).padStart(2, '0');
    return minutes + ':' + seconds;
  }

  function formatSessionDuration(ms) {
    const totalSeconds = Math.max(0, Math.floor((ms || 0) / 1000));
    const hours = Math.floor(totalSeconds / 3600);
    const minutes = Math.floor((totalSeconds % 3600) / 60);
    const seconds = totalSeconds % 60;

    if (hours > 0) {
      return hours + 'h ' + minutes + 'm';
    }

    return minutes + 'm ' + seconds + 's';
  }

  function ensureUiTicker() {
    if (uiTickHandle) {
      return;
    }

    uiTickHandle = window.setInterval(function() {
      renderLiveMetrics();
    }, 1000);
  }

  function stopUiTicker() {
    if (!uiTickHandle) {
      return;
    }

    window.clearInterval(uiTickHandle);
    uiTickHandle = null;
  }

  function setActiveSession(session) {
    activeSession = session || null;

    if (!activeSession) {
      activeSessionSyncedAt = 0;
      activeTrackSyncedAt = 0;
      stopUiTicker();
      return;
    }

    activeSessionSyncedAt = Date.now();
    activeTrackSyncedAt = activeSession.currentTrack ? activeSessionSyncedAt : 0;
    ensureUiTicker();
  }

  function renderSessionDuration() {
    if (!activeSession) {
      return;
    }

    const elapsedMs = activeSession.endedAt ? 0 : Math.max(0, Date.now() - activeSessionSyncedAt);
    document.getElementById('statDuration').textContent = formatSessionDuration(
      (activeSession.durationMs || 0) + elapsedMs
    );
  }

  function renderTrackProgress() {
    if (!activeSession?.currentTrack) {
      return;
    }

    const track = activeSession.currentTrack;
    const durationMs = track.durationMs || 0;
    const durationLabel = track.durationLabel || formatTrackDuration(durationMs);
    const elapsedMs =
      track.isPlaying && activeTrackSyncedAt
        ? Math.max(0, Date.now() - activeTrackSyncedAt)
        : 0;
    const progressMs = Math.min(durationMs, Math.max(0, (track.progressMs || 0) + elapsedMs));

    document.getElementById('npProgress').textContent =
      formatTrackDuration(progressMs) + ' / ' + durationLabel;

    const progressPercent = durationMs
      ? Math.min(100, Math.round((progressMs / durationMs) * 100))
      : 0;
    document.getElementById('npProgressBar').style.width = progressPercent + '%';
  }

  function renderLiveMetrics() {
    renderSessionDuration();
    renderTrackProgress();
  }

  function formatListenTime(timestamp) {
    return new Date(timestamp).toLocaleTimeString('en-US', {
      hour: 'numeric',
      minute: '2-digit',
    });
  }

  function openSpotifyTarget(desktopUrl, webUrl) {
    if (!desktopUrl && !webUrl) {
      return;
    }

    if (!desktopUrl) {
      window.location.assign(webUrl);
      return;
    }

    let cleanedUp = false;
    let fallbackTimer = null;
    let appLaunchObserved = false;

    function cleanup() {
      if (cleanedUp) {
        return;
      }

      cleanedUp = true;
      if (fallbackTimer) {
        window.clearTimeout(fallbackTimer);
      }

      window.removeEventListener('blur', cancelFallback);
      window.removeEventListener('pagehide', cancelFallback);
      document.removeEventListener('visibilitychange', cancelFallback);
    }

    function cancelFallback() {
      if (
        document.hidden ||
        document.visibilityState === 'hidden' ||
        document.hasFocus() === false
      ) {
        appLaunchObserved = true;
        cleanup();
      }
    }

    window.addEventListener('blur', cancelFallback, { once: true });
    window.addEventListener('pagehide', cancelFallback, { once: true });
    document.addEventListener('visibilitychange', cancelFallback);

    fallbackTimer = window.setTimeout(function() {
      cleanup();

      if (!appLaunchObserved && webUrl) {
        window.location.assign(webUrl);
      }
    }, 2200);

    const launcherLink = document.createElement('a');
    launcherLink.href = desktopUrl;
    launcherLink.style.display = 'none';
    document.body.appendChild(launcherLink);
    launcherLink.click();
    launcherLink.remove();
  }

  function renderSession(session) {
    setActiveSession(session);

    document.getElementById('sessionTitle').textContent = session.label;
    document.getElementById('sessionAvatar').textContent = session.emoji;
    document.getElementById('statTracks').textContent = session.trackCount;
    document.getElementById('statArtists').textContent = session.uniqueArtistCount;
    document.getElementById('statStatus').textContent = session.playbackStatus;

    sessionStorage.setItem('selectedLabel', session.label);
    sessionStorage.setItem('selectedEmoji', session.emoji);

    renderNowPlaying(session.currentTrack);
    renderTrackHistory(session.tracks);
    renderLiveMetrics();
  }

  function renderNowPlaying(track) {
    const emptyState = document.getElementById('npEmpty');
    const content = document.getElementById('npContent');

    if (!track) {
      emptyState.style.display = 'block';
      content.style.display = 'none';
      return;
    }

    emptyState.style.display = 'none';
    content.style.display = 'block';

    document.getElementById('npArt').src = track.albumArt || '';
    document.getElementById('npArt').alt = track.album;
    document.getElementById('npTitle').textContent = track.name;
    document.getElementById('npArtist').textContent = track.artist;
    document.getElementById('npAlbum').textContent = track.album;
    document.getElementById('npLength').textContent = track.durationLabel;
    document.getElementById('npProgress').textContent =
      track.progressLabel + ' / ' + track.durationLabel;

    const progressPercent = track.durationMs
      ? Math.min(100, Math.round((track.progressMs / track.durationMs) * 100))
      : 0;
    document.getElementById('npProgressBar').style.width = progressPercent + '%';

    const trackLink = document.getElementById('npLink');
    if (track.externalUrl) {
      trackLink.href = track.externalUrl;
      trackLink.textContent = track.isPlaying ? 'Open live track' : 'Open paused track';
      trackLink.style.pointerEvents = 'auto';
      trackLink.style.opacity = '1';
      trackLink.onclick = function(event) {
        event.preventDefault();
        openSpotifyTarget(track.desktopUrl, track.externalUrl);
      };
    } else {
      trackLink.removeAttribute('href');
      trackLink.textContent = 'Link unavailable';
      trackLink.style.pointerEvents = 'none';
      trackLink.style.opacity = '0.7';
      trackLink.onclick = null;
    }
  }

  function renderTrackHistory(tracks) {
    const list = document.getElementById('trackList');
    list.innerHTML = '';

    if (!tracks.length) {
      const emptyCard = document.createElement('div');
      emptyCard.className = 'track-empty';
      emptyCard.textContent = 'Start playback in Spotify and your session history will appear here.';
      list.appendChild(emptyCard);
      return;
    }

    tracks.forEach(function(track, index) {
      const row = document.createElement('div');
      row.className = 'track-row';

      const number = document.createElement('span');
      number.className = 'track-num';
      number.textContent = tracks.length - index;

      const art = document.createElement('img');
      art.className = 'track-art';
      art.src = track.albumArt || '';
      art.alt = track.album;

      const meta = document.createElement('div');
      meta.className = 'track-meta';

      const name = document.createElement('p');
      name.className = 'track-name';
      name.textContent = track.name;

      const artist = document.createElement('p');
      artist.className = 'track-artist';
      artist.textContent = track.artist;

      const time = document.createElement('span');
      time.className = 'track-dur';
      time.textContent = formatListenTime(track.startedAt);

      meta.appendChild(name);
      meta.appendChild(artist);
      row.appendChild(number);
      row.appendChild(art);
      row.appendChild(meta);
      row.appendChild(time);
      list.appendChild(row);
    });
  }

  async function refreshSession() {
    const response = await fetch('/api/session/active');

    if (response.status === 401) {
      window.location.href = '/login';
      return;
    }

    if (response.status === 404) {
      showMessage('There is no active session right now. Start one from the home page.', 'error');
      endBtn.disabled = true;
      endBtnLabel.textContent = 'No Active Session';
      setActiveSession(null);
      if (pollHandle) {
        clearInterval(pollHandle);
      }
      return;
    }

    const payload = await response.json();

    if (!response.ok) {
      throw new Error(payload.message || 'The active session could not be loaded.');
    }

    renderSession(payload.session);

    if (payload.warning) {
      showMessage(payload.warning, 'info');
      return;
    }

    showMessage('', '');
  }

  async function handleEndSession(event) {
    event.preventDefault();

    if (isEndingSession) {
      return;
    }

    isEndingSession = true;
    endBtn.disabled = true;
    endBtnLabel.textContent = 'Creating Playlist...';
    showMessage('Saving your session and creating the Spotify playlist now.', 'info');

    try {
      const response = await fetch('/api/session/end', {
        method: 'POST',
      });

      if (response.status === 401) {
        window.location.href = '/login';
        return;
      }

      const payload = await response.json();

      if (!response.ok) {
        throw new Error(payload.message || 'The session playlist could not be created.');
      }

      sessionStorage.setItem('newPlaylist', 'true');
      if (payload.playlist && payload.playlist.id) {
        sessionStorage.setItem('lastCreatedPlaylistId', payload.playlist.id);
      }

      window.location.href = '/playlists';
    } catch (error) {
      showMessage(error.message, 'error');
      endBtn.disabled = false;
      endBtnLabel.textContent = 'End Session';
      isEndingSession = false;
    }
  }

  async function bootSessionPage() {
    try {
      await refreshSession();
      pollHandle = setInterval(function() {
        refreshSession().catch(function(error) {
          showMessage(error.message, 'error');
        });
      }, 8000);
    } catch (error) {
      showMessage(error.message, 'error');
    }
  }

  bootSessionPage();
</script>
