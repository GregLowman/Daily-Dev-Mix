<!-- Beginning Styling Choices -->

<style>
  /* ── Base ── */
  body {
    background: radial-gradient(ellipse 100% 45% at 50% 0%, #0d2b1a 0%, #000000 60%);
    color: #fff;
    font-family: 'Figtree', sans-serif;
    min-height: 100vh;
    margin: 0;
    -webkit-font-smoothing: antialiased;
  }

  .page-wrap {
    min-height: 100vh;
    padding: 24px;
  }
  @media(min-width:768px){ .page-wrap { padding: 32px; } }

  .page-inner {
    max-width: 1160px;
    margin: 0 auto;
  }

  /* ── Header row ── */
  .header-row {
    display: flex;
    align-items: center;
    gap: 24px;
    margin-bottom: 32px;
    flex-wrap: wrap;
  }

  .back-btn {
    width: 44px; height: 44px;
    border-radius: 50%;
    background: rgba(0,0,0,0.4);
    border: 1px solid #282828;
    color: #fff;
    display: flex; align-items: center; justify-content: center;
    cursor: pointer;
    text-decoration: none;
    flex-shrink: 0;
    font-size: 1.1rem;
    transition: background 0.18s;
  }
  .back-btn:hover { background: #282828; }

  /* Green circle with emoji */
  .session-avatar {
    width: 64px; height: 64px;
    border-radius: 50%;
    background: linear-gradient(135deg, #1DB954, #1ED760);
    display: flex; align-items: center; justify-content: center;
    font-size: 1.75rem;
    flex-shrink: 0;
  }

  /* "Live Session" badge + title */
  .session-label-wrap { flex: 1; min-width: 0; }
  .live-badge {
    display: flex;
    align-items: center;
    gap: 6px;
    color: #1DB954;
    font-size: 0.78rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 1.5px;
    margin-bottom: 4px;
  }
  .live-dot {
    width: 8px; height: 8px;
    border-radius: 50%;
    background: #1DB954;
    animation: pulse 1.5s ease-in-out infinite;
  }
  @keyframes pulse { 0%,100%{opacity:1} 50%{opacity:0.35} }

  .session-title {
    font-size: clamp(1.8rem, 5vw, 2.8rem);
    font-weight: 900;
    letter-spacing: -1px;
    line-height: 1.05;
  }

  /* End session button */
  .end-btn {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 12px 24px;
    border-radius: 999px;
    background: #fff;
    color: #000;
    font-size: 0.95rem;
    font-weight: 700;
    border: none;
    cursor: pointer;
    text-decoration: none;
    flex-shrink: 0;
    transition: transform 0.18s, background 0.18s;
  }
  .end-btn:hover { transform: scale(1.05); background: #e8e8e8; }
  .end-btn svg { width: 18px; height: 18px; flex-shrink: 0; }

  /* ── Session stats (4 cards) ── */
  .stats-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 14px;
    margin-bottom: 32px;
  }
  @media(min-width:640px){ .stats-grid { grid-template-columns: repeat(4, 1fr); } }

  .stat-card {
    padding: 20px;
    border-radius: 10px;
    background: #181818;
  }
  .stat-card svg { width: 24px; height: 24px; margin-bottom: 12px; }
  .stat-value { font-size: 1.9rem; font-weight: 900; letter-spacing: -0.5px; margin-bottom: 4px; }
  .stat-value.status-value { font-size: 1.35rem; letter-spacing: 0; }
  .stat-label { font-size: 0.82rem; color: #B3B3B3; }

  .icon-green  { color: #1DB954; }
  .icon-blue   { color: #60a5fa; }
  .icon-yellow { color: #facc15; }
  .icon-purple { color: #c084fc; }

  /* ── Section heading ── */
  .section-heading {
    font-size: 1.5rem;
    font-weight: 700;
    margin-bottom: 16px;
  }

  .session-message {
    display: none;
    margin-bottom: 24px;
    padding: 16px 18px;
    border-radius: 10px;
    background: #181818;
    border: 1px solid #282828;
    line-height: 1.5;
  }
  .session-message.visible { display: block; }
  .session-message.error {
    background: rgba(127,29,29,0.35);
    border-color: rgba(248,113,113,0.35);
  }
  .session-message.info {
    background: rgba(29,185,84,0.12);
    border-color: rgba(29,185,84,0.35);
  }

  /* ── Now playing card ── */
  .now-playing-card {
    padding: 24px;
    border-radius: 10px;
    background: #181818;
    margin-bottom: 32px;
    transition: background 0.18s;
  }
  .now-playing-card:hover { background: #222; }

  /* Empty state shown before first track loads */
  .now-playing-empty {
    text-align: center;
    padding: 32px;
  }
  .now-playing-empty svg { width: 48px; height: 48px; color: #535353; margin: 0 auto 12px; display: block; }
  .now-playing-empty p { color: #B3B3B3; }

  /* Track info row */
  .np-row {
    display: flex;
    align-items: center;
    gap: 16px;
  }

  /* Album art with pulsing green overlay */
  .art-wrap {
    position: relative;
    flex-shrink: 0;
  }
  .album-art {
    width: 96px; height: 96px;
    border-radius: 6px;
    object-fit: cover;
    box-shadow: 0 4px 20px rgba(0,0,0,0.5);
    display: block;
    /* Fallback background while image loads */
    background: #282828;
  }
  .art-pulse {
    position: absolute;
    inset: 0;
    border-radius: 6px;
    background: rgba(29,185,84,0.2);
    display: flex; align-items: center; justify-content: center;
    animation: artPulse 1.5s ease-in-out infinite;
  }
  @keyframes artPulse { 0%,100%{opacity:1} 50%{opacity:0.4} }
  .art-dot {
    width: 12px; height: 12px;
    border-radius: 50%;
    background: #1DB954;
    animation: pulse 1.5s ease-in-out infinite;
  }

  .np-info { flex: 1; min-width: 0; }
  .np-title  { font-size: 1.2rem; font-weight: 700; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; margin-bottom: 4px; }
  .np-artist { color: #B3B3B3; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; margin-bottom: 2px; }
  .np-album  { font-size: 0.85rem; color: #535353; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }

  .track-detail-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 12px;
    margin-top: 20px;
  }
  .track-detail-card {
    border-radius: 8px;
    background: rgba(0,0,0,0.22);
    padding: 14px;
  }
  .track-detail-label {
    color: #B3B3B3;
    font-size: 0.8rem;
    margin-bottom: 8px;
  }
  .track-detail-value {
    font-size: 0.95rem;
    font-weight: 700;
  }
  .progress-bar {
    height: 6px;
    background: #282828;
    border-radius: 999px;
    overflow: hidden;
    margin-bottom: 8px;
  }
  .progress-fill {
    height: 100%;
    width: 0%;
    background: linear-gradient(90deg, #1DB954, #1ED760);
    transition: width 0.4s ease;
  }
  .track-link {
    color: #1DB954;
    text-decoration: none;
  }
  .track-link:hover { color: #1ED760; }
  @media(max-width:640px) {
    .np-row { align-items: flex-start; }
    .track-detail-grid { grid-template-columns: 1fr; }
  }

  /* ── Track history list ── */
  .track-list {
    display: flex;
    flex-direction: column;
    gap: 8px;
    max-height: 500px;
    overflow-y: auto;
    padding-right: 4px;
  }

  /* Custom scrollbar */
  .track-list::-webkit-scrollbar { width: 4px; }
  .track-list::-webkit-scrollbar-track { background: transparent; }
  .track-list::-webkit-scrollbar-thumb { background: #333; border-radius: 2px; }

  .track-row {
    display: flex;
    align-items: center;
    gap: 14px;
    padding: 12px 14px;
    border-radius: 8px;
    background: #181818;
    transition: background 0.15s;
  }
  .track-row:hover { background: #282828; }

  .track-num {
    font-size: 0.85rem;
    color: #B3B3B3;
    width: 22px;
    text-align: right;
    flex-shrink: 0;
  }
  .track-art {
    width: 52px; height: 52px;
    border-radius: 4px;
    object-fit: cover;
    flex-shrink: 0;
    background: #282828;
  }
  .track-meta { flex: 1; min-width: 0; }
  .track-name   { font-weight: 600; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
  .track-artist { font-size: 0.85rem; color: #B3B3B3; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; margin-top: 2px; }
  .track-dur { font-size: 0.85rem; color: #B3B3B3; flex-shrink: 0; }
  .track-empty {
    padding: 20px;
    border-radius: 8px;
    background: #181818;
    color: #B3B3B3;
    line-height: 1.6;
  }

  /* ── Fade-up animation ── */
  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(20px); }
    to   { opacity: 1; transform: translateY(0); }
  }
  .fu { animation: fadeUp 0.45s cubic-bezier(.22,.68,0,1.1) both; }
  .d1 { animation-delay: 0.08s; }
  .d2 { animation-delay: 0.16s; }
  .d3 { animation-delay: 0.24s; }
</style>

