{{> message}}

<!-- Beginning Styling Choices -->
<style>
  :root {
    --green:        #1DB954;
    --green-bright: #1ED760;
    --black:        #000000;
    --surface:      #121212;
    --surface-2:    #181818;
    --surface-3:    #282828;
    --border:       rgba(255,255,255,0.08);
    --text:         #ffffff;
    --sub:          #B3B3B3;
    --muted:        #535353;
  }

  body {
    background: var(--black);
    color: var(--text);
    font-family: 'Figtree', sans-serif;
    -webkit-font-smoothing: antialiased;
    overflow-x: hidden;
  }

  a { text-decoration: none; color: inherit; }
  button { font-family: inherit; cursor: pointer; }

  /* ── Navbar ── */
  .lp-nav {
    position: fixed;
    top: 0; left: 0; right: 0;
    z-index: 100;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 18px 40px;
    background: rgba(0,0,0,0.85);
    backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--border);
    transition: padding 0.2s;
  }

  .lp-nav-brand {
    display: flex;
    align-items: center;
    gap: 10px;
    font-weight: 800;
    font-size: 1.1rem;
    letter-spacing: -0.3px;
  }

  .lp-nav-brand svg { width: 24px; height: 24px; fill: var(--green); }

  .lp-nav-links {
    display: flex;
    align-items: center;
    gap: 8px;
    list-style: none;
    margin: 0; padding: 0;
  }

  .lp-nav-links a {
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--sub);
    padding: 8px 14px;
    border-radius: 4px;
    transition: color 0.15s;
  }
  .lp-nav-links a:hover { color: var(--text); }

  .lp-nav-cta {
    background: var(--text) !important;
    color: #000 !important;
    font-weight: 700 !important;
    border-radius: 500px !important;
    padding: 10px 22px !important;
    font-size: 0.875rem !important;
    transition: transform 0.15s, background 0.15s !important;
  }
  .lp-nav-cta:hover { background: var(--sub) !important; transform: scale(1.03); }

  .lp-nav-mobile-btn {
    display: none;
    background: none;
    border: none;
    color: var(--text);
    font-size: 1.5rem;
    padding: 4px;
  }

  @media (max-width: 768px) {
    .lp-nav { padding: 16px 20px; }
    .lp-nav-links { display: none; }
    .lp-nav-mobile-btn { display: block; }
  }

  /* ── Hero ── */
  .hero {
    min-height: 100vh;
    display: flex;
    align-items: center;
    padding: 10px 0 80px;
    background: var(--black);
  }

  .hero-eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: rgba(29,185,84,0.12);
    border: 1px solid rgba(29,185,84,0.25);
    color: var(--green);
    font-size: 0.78rem;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    padding: 6px 14px;
    border-radius: 500px;
    margin-bottom: 28px;
  }

  .hero-eyebrow span {
    width: 6px; height: 6px;
    background: var(--green);
    border-radius: 50%;
    display: inline-block;
    animation: blink 2s ease-in-out infinite;
  }

  @keyframes blink {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.3; }
  }

  .hero-title {
    font-size: clamp(2.8rem, 7vw, 5.5rem);
    font-weight: 900;
    line-height: 1.05;
    letter-spacing: -2px;
    color: var(--text);
    margin-bottom: 24px;
  }

  .hero-title .green { color: var(--green); }

  .hero-subtitle {
    font-size: 1.1rem;
    color: var(--sub);
    line-height: 1.7;
    max-width: 460px;
    margin-bottom: 40px;
    font-weight: 400;
  }

  .hero-actions { display: flex; align-items: center; gap: 16px; flex-wrap: wrap; }

  .btn-green {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    background: var(--green);
    color: #000;
    font-weight: 700;
    font-size: 0.95rem;
    padding: 14px 28px;
    border-radius: 500px;
    border: none;
    transition: background 0.15s, transform 0.15s;
    text-decoration: none;
  }
  .btn-green:hover { background: var(--green-bright); color: #000; transform: scale(1.03); }
  .btn-green svg { width: 20px; height: 20px; fill: #000; flex-shrink: 0; }

  .btn-outline {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: transparent;
    color: var(--text);
    font-weight: 600;
    font-size: 0.95rem;
    padding: 13px 26px;
    border-radius: 500px;
    border: 1px solid rgba(255,255,255,0.2);
    transition: border-color 0.15s, background 0.15s;
    text-decoration: none;
  }
  .btn-outline:hover { border-color: var(--text); background: rgba(255,255,255,0.05); color: var(--text); }

  /* Hero player card */
  .player-card {
    background: var(--surface-2);
    border-radius: 16px;
    padding: 28px;
    border: 1px solid var(--border);
  }

  .player-now {
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--muted);
    margin-bottom: 20px;
  }

  .player-track { display: flex; align-items: center; gap: 16px; margin-bottom: 20px; }

  .player-art {
    width: 56px; height: 56px;
    background: linear-gradient(135deg, #1DB954, #0a5c2a);
    border-radius: 8px;
    display: flex; align-items: center; justify-content: center;
    font-size: 1.5rem;
    flex-shrink: 0;
  }

  .player-track-name { font-weight: 700; font-size: 1rem; color: var(--text); margin-bottom: 4px; }
  .player-track-sub  { font-size: 0.82rem; color: var(--sub); }

  .player-bar-wrap {
    height: 4px;
    background: var(--surface-3);
    border-radius: 2px;
    margin-bottom: 8px;
  }

  .player-bar-fill { height: 100%; width: 38%; background: var(--green); border-radius: 2px; }

  .player-times {
    display: flex;
    justify-content: space-between;
    font-size: 0.7rem;
    color: var(--muted);
    margin-bottom: 20px;
  }

  .player-controls {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 20px;
    margin-bottom: 24px;
  }

  .ctrl {
    background: none; border: none;
    color: var(--sub); font-size: 1.1rem;
    cursor: pointer; transition: color 0.15s; padding: 0;
    display: flex; align-items: center;
  }
  .ctrl:hover { color: var(--text); }

  .ctrl-play {
    width: 44px; height: 44px;
    background: var(--text); color: #000;
    border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
    font-size: 1.15rem;
    transition: transform 0.15s, background 0.15s;
    border: none; cursor: pointer;
  }
  .ctrl-play:hover { transform: scale(1.06); background: var(--sub); }

  .player-tags {
    display: flex; flex-direction: column; gap: 8px;
    padding-top: 20px;
    border-top: 1px solid var(--border);
  }

  .player-tag {
    display: flex; align-items: center; gap: 10px;
    background: var(--surface-3);
    border-radius: 8px;
    padding: 10px 14px;
    font-size: 0.8rem;
  }

  .tag-dot { width: 8px; height: 8px; border-radius: 50%; flex-shrink: 0; }
  .tag-label { color: var(--sub); }
  .tag-val { margin-left: auto; color: var(--green); font-weight: 600; }

  /* ── Section base ── */
  .lp-section { padding: 96px 0; }

  .lp-section-dark {
    background: var(--surface);
    border-top: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
  }

  .eyebrow {
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--green);
    margin-bottom: 16px;
    display: block;
  }

  .section-title {
    font-size: clamp(1.8rem, 4vw, 2.8rem);
    font-weight: 900;
    letter-spacing: -1px;
    line-height: 1.1;
    color: var(--text);
    margin-bottom: 16px;
  }

  .section-sub {
    font-size: 1rem;
    color: var(--sub);
    line-height: 1.7;
    max-width: 520px;
  }

  /* ── Steps ── */
  .step-card {
    background: var(--surface-2);
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 32px;
    height: 100%;
    transition: border-color 0.2s, background 0.2s;
  }
  .step-card:hover { border-color: rgba(29,185,84,0.3); background: var(--surface-3); }

  .step-num {
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    color: var(--green);
    margin-bottom: 16px;
    display: block;
  }

  .step-icon {
    width: 48px; height: 48px;
    background: rgba(29,185,84,0.1);
    border-radius: 12px;
    display: flex; align-items: center; justify-content: center;
    font-size: 1.3rem;
    margin-bottom: 20px;
    color: var(--green);
  }

  .step-title { font-size: 1.1rem; font-weight: 800; color: var(--text); margin-bottom: 10px; }
  .step-desc  { font-size: 0.9rem; color: var(--sub); line-height: 1.7; margin: 0; }

  /* ── Features ── */
  .feature-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 1px;
    background: var(--border);
    border: 1px solid var(--border);
    border-radius: 16px;
    overflow: hidden;
  }

  .feature-item { background: var(--surface-2); padding: 32px; transition: background 0.2s; }
  .feature-item:hover { background: var(--surface-3); }

  .feature-icon {
    width: 44px; height: 44px;
    background: rgba(29,185,84,0.1);
    border-radius: 10px;
    display: flex; align-items: center; justify-content: center;
    font-size: 1.2rem;
    color: var(--green);
    margin-bottom: 16px;
  }

  .feature-title { font-size: 1rem; font-weight: 800; color: var(--text); margin-bottom: 8px; }
  .feature-desc  { font-size: 0.875rem; color: var(--sub); line-height: 1.7; margin: 0; }

  /* ── Stats ── */
  .stats-section { background: var(--green); padding: 80px 0; }

  .stat-block { text-align: center; padding: 20px; }

  .stat-num {
    font-size: clamp(2.5rem, 5vw, 4rem);
    font-weight: 900;
    letter-spacing: -2px;
    color: #000;
    line-height: 1;
    margin-bottom: 8px;
  }

  .stat-label { font-size: 0.85rem; font-weight: 600; color: rgba(0,0,0,0.55); }
  .stat-divider { width: 1px; background: rgba(0,0,0,0.15); align-self: stretch; }

  /* ── Testimonials ── */
  .testi-card {
    background: var(--surface-2);
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 28px;
    height: 100%;
    transition: border-color 0.2s;
  }
  .testi-card:hover { border-color: rgba(29,185,84,0.3); }

  .stars { color: var(--green); font-size: 0.85rem; margin-bottom: 14px; letter-spacing: 2px; }
  .testi-quote { font-size: 0.95rem; color: var(--sub); line-height: 1.75; margin-bottom: 20px; }
  .testi-author { display: flex; align-items: center; gap: 12px; }

  .testi-avatar {
    width: 40px; height: 40px;
    border-radius: 50%;
    background: var(--surface-3);
    display: flex; align-items: center; justify-content: center;
    font-size: 1rem; flex-shrink: 0;
  }

  .testi-name { font-weight: 700; font-size: 0.9rem; color: var(--text); }
  .testi-role { font-size: 0.78rem; color: var(--muted); margin-top: 2px; }

  /* ── Pricing ── */
  .price-card {
    background: var(--surface-2);
    border: 1px solid var(--border);
    border-radius: 16px;
    padding: 36px;
    height: 100%;
  }
  .price-card.featured { border-color: var(--green); background: rgba(29,185,84,0.05); }

  .price-badge {
    display: inline-block;
    background: var(--green);
    color: #000;
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    padding: 4px 12px;
    border-radius: 500px;
    margin-bottom: 20px;
  }

  .price-tier { font-size: 0.8rem; font-weight: 700; color: var(--sub); text-transform: uppercase; letter-spacing: 0.1em; margin-bottom: 8px; }
  .price-num  { font-size: 3rem; font-weight: 900; letter-spacing: -2px; color: var(--text); line-height: 1; margin-bottom: 4px; }
  .price-per  { font-size: 0.85rem; color: var(--muted); margin-bottom: 24px; }

  .price-divider { border: none; border-top: 1px solid var(--border); margin: 24px 0; }

  .price-features { list-style: none; padding: 0; margin: 0 0 28px; }
  .price-features li {
    display: flex; align-items: center; gap: 10px;
    font-size: 0.9rem; color: var(--sub); padding: 7px 0;
  }
  .price-features li i { font-size: 1rem; }
  .price-features li i.bi-check-circle-fill { color: var(--green); }
  .price-features li i.bi-x-circle { color: var(--muted); }

  /* ── CTA ── */
  .cta-section { padding: 100px 0; text-align: center; background: var(--black); }
  .cta-section .section-sub { margin: 0 auto 40px; }

  /* ── Footer ── */
  .lp-footer { background: var(--surface); border-top: 1px solid var(--border); padding: 60px 0 32px; }

  .footer-brand { display: flex; align-items: center; gap: 10px; font-weight: 800; font-size: 1.1rem; margin-bottom: 10px; }
  .footer-brand svg { width: 22px; height: 22px; fill: var(--green); }
  .footer-tagline { font-size: 0.85rem; color: var(--muted); }

  .footer-col-title {
    font-size: 0.72rem; font-weight: 700;
    letter-spacing: 0.1em; text-transform: uppercase;
    color: var(--sub); margin-bottom: 16px;
  }

  .footer-link { display: block; font-size: 0.875rem; color: var(--muted); margin-bottom: 10px; transition: color 0.15s; }
  .footer-link:hover { color: var(--text); }

  .footer-bottom {
    margin-top: 48px; padding-top: 24px;
    border-top: 1px solid var(--border);
    display: flex; justify-content: space-between; align-items: center;
    flex-wrap: wrap; gap: 16px;
  }

  .footer-copy { font-size: 0.8rem; color: var(--muted); }
 
  /* ── Animations ── */
  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(20px); }
    to   { opacity: 1; transform: translateY(0); }
  }
  .fade-up { animation: fadeUp 0.6s ease forwards; }
  .d1 { animation-delay: 0.05s; opacity: 0; }
  .d2 { animation-delay: 0.15s; opacity: 0; }
  .d3 { animation-delay: 0.25s; opacity: 0; }
  .d4 { animation-delay: 0.35s; opacity: 0; }
</style>

<!-- Beginning of Page Layout -->

