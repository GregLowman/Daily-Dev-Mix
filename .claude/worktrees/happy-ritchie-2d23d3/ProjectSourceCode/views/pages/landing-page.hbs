<!-- How It Works -->
<section class="lp-section lp-section-dark" id="how-it-works">
  <div class="container">
    <div class="text-center mb-5">
      <span class="eyebrow">How it works</span>
      <h2 class="section-title">Three steps to your perfect mix</h2>
      <p class="section-sub mx-auto">Just a few clicks to start your enhanced listening journey.</p>
    </div>
    <div class="row g-4">
      <div class="col-md-4">
        <div class="step-card">
          <span class="step-num">STEP 01</span>
          <div class="step-icon"><i class="bi bi-spotify"></i></div>
          <div class="step-title">Connect Spotify</div>
          <p class="step-desc">Just log into your existing spotify account and let Daily Dev Mix connect to it.</p>
        </div>
      </div>
      <div class="col-md-4">
        <div class="step-card">
          <span class="step-num">STEP 02</span>
          <div class="step-icon"><i class="bi bi-activity"></i></div>
          <div class="step-title">We Read Your Session</div>
          <p class="step-desc">Whenver you start jamming out, just click start session in Daily Dev Mix. We will start a session to listen to the songs you bump to.</p>
        </div>
      </div>
      <div class="col-md-4">
        <div class="step-card">
          <span class="step-num">STEP 03</span>
          <div class="step-icon"><i class="bi bi-music-note-list"></i></div>
          <div class="step-title">Get Your Mix</div>
          <p class="step-desc">Daily Dev Mix takes the data from your sessions and maticulously creates your own personalized playlists!</p>
        </div>
      </div>
    </div>
  </div>
</section>


<!-- Features -->
<section class="lp-section" id="features">
  <div class="container">
    <div class="row align-items-end mb-5">
      <div class="col-lg-6">
        <span class="eyebrow">Features</span>
        <h2 class="section-title">Everything your ears need</h2>
        <p class="section-sub">Stop spending hours looking for new music. Just click and go.</p>
      </div>
