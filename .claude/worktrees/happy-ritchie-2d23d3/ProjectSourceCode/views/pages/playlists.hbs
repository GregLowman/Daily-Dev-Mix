<!-- Beginning Styling Choices -->

<style>
  /* ── Base ── */
  body {
    background: radial-gradient(ellipse 100% 45% at 50% 0%, #0d2b1a 0%, #000000 60%);
    color: #fff;
    font-family: 'Figtree', sans-serif;
    min-height: 100vh;
    margin: 0;
    -webkit-font-smoothing: antialiased;
  }
  .page-wrap {
    min-height: 100vh;
    padding: 24px;
  }
  @media(min-width:768px){ .page-wrap { padding: 32px; } }


  .page-inner {
    max-width: 1280px;
    margin: 0 auto;
  }

  /* ── Header row ── */
  .header-row {
    display: flex;
    align-items: center;
    gap: 24px;
    margin-bottom: 32px;
  }

  .back-btn {
    width: 44px; height: 44px;
    border-radius: 50%;
    background: rgba(0,0,0,0.4);
    border: 1px solid #282828;
    color: #fff;
    display: flex; align-items: center; justify-content: center;
    cursor: pointer;
    text-decoration: none;
    flex-shrink: 0;
    transition: background 0.18s;
    font-size: 1.1rem;
  }
  .back-btn:hover { background: #282828; }

  .page-title {
    font-size: clamp(2.5rem, 7vw, 4.5rem);
    font-weight: 900;
    letter-spacing: -2px;
    line-height: 1.0;
    margin-bottom: 8px;
  }
  .page-subtitle {
    font-size: 1.1rem;
    color: #B3B3B3;
  }

  /* ── Success banner ── */
  .success-banner {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 20px;
    border-radius: 10px;
    background: rgba(29,185,84,0.1);
    border: 1px solid rgba(29,185,84,0.3);
    margin-bottom: 32px;
    /* Hidden by default, shown via JS */
    display: none;
  }
  .success-banner.visible { display: flex; }
  .banner-check {
    color: #1DB954;
    flex-shrink: 0;
  }
  .banner-title {
    font-size: 1.05rem;
    font-weight: 700;
    margin-bottom: 2px;
  }
  .banner-sub {
    font-size: 0.875rem;
    color: #B3B3B3;
  }

  /* ── Empty state ── */
  .empty-state {
    text-align: center;
    padding: 96px 0;
    display: none;
  }
  .empty-state.visible { display: block; }
  .empty-icon {
    width: 96px; height: 96px;
    border-radius: 50%;
    background: #282828;
    display: flex; align-items: center; justify-content: center;
    margin: 0 auto 24px;
    font-size: 2.5rem;
  }
  .empty-title {
    font-size: 2rem;
    font-weight: 900;
    margin-bottom: 12px;
  }
  .empty-desc {
    font-size: 1.05rem;
    color: #B3B3B3;
    max-width: 400px;
    margin: 0 auto 32px;
    line-height: 1.6;
  }
  .btn-green {
    display: inline-flex; align-items: center; gap: 10px;
    padding: 16px 32px;
    border-radius: 999px;
    background: #1DB954;
    color: #000;
    font-size: 1rem;
    font-weight: 700;
    border: none;
    cursor: pointer;
    text-decoration: none;
    transition: background 0.18s, transform 0.18s;
  }
  .btn-green:hover { background: #1ED760; transform: scale(1.05); }

  /* ── Playlist grid ── */
  .playlist-grid {
    display: grid;
    gap: 24px;
    grid-template-columns: repeat(2, 1fr);
  }
  @media(min-width:640px)  { .playlist-grid { grid-template-columns: repeat(3, 1fr); } }
  @media(min-width:1024px) { .playlist-grid { grid-template-columns: repeat(4, 1fr); } }
  @media(min-width:1280px) { .playlist-grid { grid-template-columns: repeat(5, 1fr); } }

  /* ── Playlist card ── */
  .playlist-card {
    padding: 16px;
    border-radius: 10px;
    background: #181818;
    cursor: pointer;
    transition: background 0.18s, transform 0.18s;
    position: relative;
  }
  .playlist-card:hover {
    background: #282828;
    transform: scale(1.02);
  }

  /* Play button appears on hover */
  .playlist-card:hover .play-btn { opacity: 1; transform: translateY(0); }

  .art-wrap {
    position: relative;
    margin-bottom: 16px;
  }
  .playlist-art {
    width: 100%;
    aspect-ratio: 1 / 1;
    border-radius: 6px;
    object-fit: cover;
    display: block;
    box-shadow: 0 4px 20px rgba(0,0,0,0.5);
    /* Fallback background if image fails */
    background: #282828;
  }
  .playlist-placeholder {
    width: 100%;
    aspect-ratio: 1 / 1;
    border-radius: 6px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 2rem;
    background: linear-gradient(135deg, rgba(29,185,84,0.3), rgba(29,185,84,0.08));
    box-shadow: 0 4px 20px rgba(0,0,0,0.5);
  }
  .play-btn {
    position: absolute;
    bottom: 8px; right: 8px;
    width: 46px; height: 46px;
    border-radius: 50%;
    background: #1DB954;
    border: none;
    cursor: pointer;
    display: flex; align-items: center; justify-content: center;
    box-shadow: 0 4px 16px rgba(0,0,0,0.5);
    opacity: 0;
    transform: translateY(6px);
    transition: opacity 0.2s, transform 0.2s;
  }
  .play-btn svg { color: #000; width: 20px; height: 20px; margin-left: 2px; }
  .playlist-card.new-playlist {
    box-shadow: 0 0 0 1px rgba(29,185,84,0.45), 0 16px 28px rgba(29,185,84,0.12);
  }

  .playlist-name {
    font-size: 0.95rem;
    font-weight: 700;
    margin-bottom: 6px;
    /* Truncate long names to one line */
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  .playlist-desc {
    font-size: 0.82rem;
    color: #B3B3B3;
    margin-bottom: 12px;
    line-height: 1.45;
    /* Clamp to 2 lines */
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .playlist-meta {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 0.75rem;
    color: #B3B3B3;
  }
  .playlist-meta svg { width: 12px; height: 12px; flex-shrink: 0; }

  /* ── Info box ── */
  .info-box {
    align-items: flex-start;
    gap: 14px;
    margin-top: 32px;
    padding: 20px;
    border-radius: 10px;
    background: #181818;
    border: 1px solid #282828;
  }
  .info-box-icon {
    width: 24px;
    height: 24px;
    flex-shrink: 0;
    color: #1DB954;
    margin-top: 2px;
  }
  .info-box-title {
    font-size: 1rem;
    font-weight: 700;
    margin-bottom: 6px;
  }
  .info-box-text {
    color: #B3B3B3;
    line-height: 1.6;
  }
  @media(max-width:640px) {
    .info-box {
      flex-direction: column;
    }
  }

  /* ── Fade-up animation ── */
  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(20px); }
    to   { opacity: 1; transform: translateY(0); }
  }
  .fu { animation: fadeUp 0.45s cubic-bezier(.22,.68,0,1.1) both; }
  .d1 { animation-delay: 0.08s; }
  .d2 { animation-delay: 0.16s; }
  .d3 { animation-delay: 0.24s; }
</style>

