<!-- Beginning Styling Choices -->

<style>
  /* ── Base ── */
  body {
    background: radial-gradient(ellipse 100% 45% at 50% 0%, #0d2b1a 0%, #000000 60%);
    color: #fff;
    font-family: 'Figtree', sans-serif;
    min-height: 100vh;
    margin: 0;
    -webkit-font-smoothing: antialiased;
  }
  .page-wrap {
    min-height: 100vh;
    padding: 24px;
  }
  @media(min-width:768px){ .page-wrap { padding: 32px; } }

  .page-inner {
    max-width: 1160px;
    margin: 0 auto;
  }

  /* ── Header row ── */
  .header-row {
    display: flex;
    align-items: center;
    gap: 24px;
    margin-bottom: 32px;
  }

  .back-btn {
    width: 44px; height: 44px;
    border-radius: 50%;
    background: rgba(0,0,0,0.4);
    border: 1px solid #282828;
    color: #fff;
    display: flex; align-items: center; justify-content: center;
    cursor: pointer;
    text-decoration: none;
    flex-shrink: 0;
    font-size: 1.1rem;
    transition: background 0.18s;
  }
  .back-btn:hover { background: #282828; }

  .page-title {
    font-size: clamp(2.5rem, 7vw, 4.5rem);
    font-weight: 900;
    letter-spacing: -2px;
    line-height: 1.0;
    margin-bottom: 8px;
  }
  .page-subtitle {
    font-size: 1.1rem;
    color: #B3B3B3;
  }

  /* ── Stats overview grid ── */
  .stats-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 14px;
    margin-bottom: 48px;
  }
  @media(min-width:640px){ .stats-grid { grid-template-columns: repeat(4, 1fr); } }

  .stat-card {
    padding: 24px;
    border-radius: 10px;
    border: 1px solid #282828;
  }
  .stat-card-purple { background: linear-gradient(135deg, rgba(168,85,247,0.1), transparent); }
  .stat-card-green  { background: linear-gradient(135deg, rgba(29,185,84,0.1),  transparent); }
  .stat-card-blue   { background: linear-gradient(135deg, rgba(59,130,246,0.1), transparent); }
  .stat-card-pink   { background: linear-gradient(135deg, rgba(236,72,153,0.1), transparent); }

  .stat-icon {
    width: 32px; height: 32px;
    margin-bottom: 12px;
  }
  .icon-purple { color: #c084fc; }
  .icon-green  { color: #1DB954; }
  .icon-blue   { color: #60a5fa; }
  .icon-pink   { color: #f472b6; }

  .stat-value {
    font-size: 2.5rem;
    font-weight: 900;
    letter-spacing: -1px;
    line-height: 1;
    margin-bottom: 4px;
  }
  .stat-label {
    font-size: 0.82rem;
    color: #B3B3B3;
  }

  /* ── Section heading ── */
  .section-heading {
    font-size: 1.5rem;
    font-weight: 700;
    margin-bottom: 24px;
  }

  /* ── Session list ── */
  .session-list {
    display: flex;
    flex-direction: column;
    gap: 14px;
  }

  .session-card {
    padding: 24px;
    border-radius: 10px;
    background: #181818;
    transition: background 0.18s;
  }
  .session-card.linked { cursor: pointer; }
  .session-card.linked:hover { background: #282828; }

  /* Top row: emoji box + title + date */
  .session-top {
    display: flex;
    align-items: center;
    gap: 16px;
    margin-bottom: 24px;
  }

  .session-emoji-box {
    width: 64px; height: 64px;
    border-radius: 10px;
    background: linear-gradient(135deg, rgba(29,185,84,0.2), rgba(29,185,84,0.05));
    border: 1px solid rgba(29,185,84,0.2);
    display: flex; align-items: center; justify-content: center;
    font-size: 1.75rem;
    flex-shrink: 0;
  }

  .session-type {
    font-size: 1.2rem;
    font-weight: 700;
    margin-bottom: 4px;
  }
  .session-date {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 0.85rem;
    color: #B3B3B3;
    flex-wrap: wrap;
  }
  .session-date svg {
    width: 14px; height: 14px;
    flex-shrink: 0;
  }

  /* Bottom row: 3 mini stat boxes */
  .session-stats {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 12px;
  }

  .mini-stat {
    text-align: center;
    padding: 14px 8px;
    border-radius: 8px;
    background: rgba(0,0,0,0.3);
  }
  .mini-stat svg {
    width: 18px; height: 18px;
    margin: 0 auto 6px;
    display: block;
  }
  .mini-stat-val {
    font-size: 1.05rem;
    font-weight: 700;
    margin-bottom: 2px;
  }
  .mini-stat-lbl {
    font-size: 0.72rem;
    color: #B3B3B3;
  }
  .session-empty {
    color: #B3B3B3;
    line-height: 1.6;
  }

  /* ── Fade-up animation ── */
  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(20px); }
    to   { opacity: 1; transform: translateY(0); }
  }
  .fu { animation: fadeUp 0.45s cubic-bezier(.22,.68,0,1.1) both; }
  .d1 { animation-delay: 0.08s; }
  .d2 { animation-delay: 0.16s; }
  .d3 { animation-delay: 0.24s; }
</style>
{{> nav}}
<!-- Beginning of Page Layout -->

<div class="page-wrap">
  <div class="page-inner">

    <!-- Header -->
    <div class="header-row fu">
      <a href="/home" class="back-btn">&#8592;</a>
      <div>
        <h1 class="page-title">Listening History</h1>
        <p class="page-subtitle">Your past sessions and insights</p>
      </div>
    </div>

    <!-- Stats overview (calculated by JS) -->
    <div class="stats-grid fu d1">
      <div class="stat-card stat-card-purple">
        <svg class="stat-icon icon-purple" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg>
        <div class="stat-value" id="statSessions">—</div>
        <div class="stat-label">Total Sessions</div>
      </div>
      <div class="stat-card stat-card-green">
        <svg class="stat-icon icon-green" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 18V5l12-2v13"/><circle cx="6" cy="18" r="3"/><circle cx="18" cy="16" r="3"/></svg>
        <div class="stat-value" id="statTracks">—</div>
        <div class="stat-label">Tracks Played</div>
      </div>
      <div class="stat-card stat-card-blue">
        <svg class="stat-icon icon-blue" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
        <div class="stat-value" id="statHours">—</div>
        <div class="stat-label">Listening Time</div>
      </div>
      <div class="stat-card stat-card-pink">
        <svg class="stat-icon icon-pink" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="23 6 13.5 15.5 8.5 10.5 1 18"/><polyline points="17 6 23 6 23 12"/></svg>
        <div class="stat-value" id="statPlaylists">—</div>
        <div class="stat-label">Playlists Created</div>
      </div>
    </div>

    <!-- Sessions list (built by JS) -->
    <div class="fu d2">
      <h2 class="section-heading">Recent Sessions</h2>
      <div class="session-list" id="sessionList"></div>
    </div>

  </div>
</div>

<!-- Beginning Script Code and Functions -->

<script>
  function formatDate(timestamp) {
    return new Date(timestamp).toLocaleDateString('en-US', {
      month: 'short',
      day: 'numeric',
      year: 'numeric',
    });
  }

  function formatTime(timestamp) {
    return new Date(timestamp).toLocaleTimeString('en-US', {
      hour: 'numeric',
      minute: '2-digit',
    });
  }

  function formatListeningTotal(totalMs) {
    const roundedHours = Math.max(0, Math.round(totalMs / 3600000));
    return roundedHours + 'h';
  }

  function openPlaylist(desktopUrl, webUrl) {
    if (!desktopUrl && !webUrl) {
      return;
    }

    if (!desktopUrl) {
      window.location.assign(webUrl);
      return;
    }

    let cleanedUp = false;
    let fallbackTimer = null;
    let appLaunchObserved = false;

    function cleanup() {
      if (cleanedUp) {
        return;
      }

      cleanedUp = true;
      if (fallbackTimer) {
        window.clearTimeout(fallbackTimer);
      }

      window.removeEventListener('blur', cancelFallback);
      window.removeEventListener('pagehide', cancelFallback);
      document.removeEventListener('visibilitychange', cancelFallback);
    }

    function cancelFallback() {
      if (
        document.hidden ||
        document.visibilityState === 'hidden' ||
        document.hasFocus() === false
      ) {
        appLaunchObserved = true;
        cleanup();
      }
    }

    window.addEventListener('blur', cancelFallback, { once: true });
    window.addEventListener('pagehide', cancelFallback, { once: true });
    document.addEventListener('visibilitychange', cancelFallback);

    fallbackTimer = window.setTimeout(function() {
      cleanup();

      if (!appLaunchObserved && webUrl) {
        window.location.assign(webUrl);
      }
    }, 2200);

    const launcherLink = document.createElement('a');
    launcherLink.href = desktopUrl;
    launcherLink.style.display = 'none';
    document.body.appendChild(launcherLink);
    launcherLink.click();
    launcherLink.remove();
  }

  function updateOverviewStats(sessions, playlistCount) {
    const totalTracks = sessions.reduce(function(sum, session) {
      return sum + session.trackCount;
    }, 0);
    const totalListeningMs = sessions.reduce(function(sum, session) {
      return sum + session.durationMs;
    }, 0);

    document.getElementById('statSessions').textContent = sessions.length;
    document.getElementById('statTracks').textContent = totalTracks;
    document.getElementById('statHours').textContent = formatListeningTotal(totalListeningMs);
    document.getElementById('statPlaylists').textContent = playlistCount;
  }

  function renderSessions(sessions) {
    const list = document.getElementById('sessionList');
    list.innerHTML = '';

    if (!sessions.length) {
      const emptyCard = document.createElement('div');
      emptyCard.className = 'session-card session-empty';
      emptyCard.textContent = 'No listening sessions have been completed yet. Finish a session to see it appear here.';
      list.appendChild(emptyCard);
      return;
    }

    sessions.forEach(function(session) {
      const card = document.createElement('div');
      card.className = 'session-card';

      if (session.playlist && session.playlist.externalUrl) {
        card.classList.add('linked');
        card.addEventListener('click', function() {
          openPlaylist(session.playlist.desktopUrl, session.playlist.externalUrl);
        });
      }

      card.innerHTML = `
        <div class="session-top">
          <div class="session-emoji-box">${session.emoji}</div>
          <div>
            <p class="session-type">${session.label}</p>
            <div class="session-date">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
              <span>${formatDate(session.startedAt)}</span>
              <span>•</span>
              <span>${formatTime(session.startedAt)} – ${formatTime(session.endedAt)}</span>
            </div>
          </div>
        </div>

        <div class="session-stats">
          <div class="mini-stat">
            <svg class="icon-green" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 18V5l12-2v13"/><circle cx="6" cy="18" r="3"/><circle cx="18" cy="16" r="3"/></svg>
            <div class="mini-stat-val">${session.trackCount}</div>
            <div class="mini-stat-lbl">Tracks</div>
          </div>
          <div class="mini-stat">
            <svg class="icon-blue" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
            <div class="mini-stat-val">${session.durationLabel}</div>
            <div class="mini-stat-lbl">Duration</div>
          </div>
          <div class="mini-stat">
            <svg style="color:#facc15;" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="23 6 13.5 15.5 8.5 10.5 1 18"/><polyline points="17 6 23 6 23 12"/></svg>
            <div class="mini-stat-val">${session.uniqueArtistCount}</div>
            <div class="mini-stat-lbl">Artists</div>
          </div>
        </div>
      `;

      list.appendChild(card);
    });
  }

  async function loadHistory() {
    const response = await fetch('/api/history');

    if (response.status === 401) {
      window.location.href = '/login';
      return;
    }

    const payload = await response.json();

    if (!response.ok) {
      throw new Error(payload.message || 'Listening history could not be loaded.');
    }

    updateOverviewStats(payload.sessions || [], payload.playlistCount || 0);
    renderSessions(payload.sessions || []);
  }

  loadHistory().catch(function(error) {
    const list = document.getElementById('sessionList');
    list.innerHTML = '';

    const errorCard = document.createElement('div');
    errorCard.className = 'session-card session-empty';
    errorCard.textContent = error.message;
    list.appendChild(errorCard);
  });
</script>
