<!-- Beginning of Script Code and Functions -->

<script>
  const storageKey = 'customListeningTopics';
  const vibeGrid = document.getElementById('vibeGrid');
  const topicModal = document.getElementById('topicModal');
  const topicName = document.getElementById('topicName');
  const topicEmoji = document.getElementById('topicEmoji');
  const topicError = document.getElementById('topicError');
  const startBtn = document.getElementById('startBtn');
  const startBtnLabel = document.getElementById('startBtnLabel');
  const sessionHint = document.getElementById('sessionHint');
  const homeMessage = document.getElementById('homeMessage');

  let selectedVibe = null;
  let activeSession = null;
  let isStarting = false;

  const getCustomTopics = () => {
    try {
      return JSON.parse(localStorage.getItem(storageKey) || '[]');
    } catch {
      return [];
    }
  };

  const saveCustomTopics = (topics) => {
    localStorage.setItem(storageKey, JSON.stringify(topics));
  };

  const activateStartButton = () => {
    startBtn.classList.replace('inactive', 'active');
  };

  function showMessage(message, type) {
    if (!message) {
      homeMessage.textContent = '';
      homeMessage.className = 'home-message';
      return;
    }

    homeMessage.textContent = message;
    homeMessage.className = 'home-message visible ' + (type || 'info');
  }

  function setStartButton(isEnabled, label) {
    startBtn.disabled = !isEnabled;
    startBtnLabel.textContent = label;
    startBtn.classList.toggle('active', isEnabled);
    startBtn.classList.toggle('inactive', !isEnabled);
  }

  async function loadActiveSessionState() {
    try {
      const response = await fetch('/api/session/active');

      if (response.status === 404) {
        activeSession = null;
        return;
      }

      if (response.status === 401) {
        window.location.href = '/login';
        return;
      }

      const payload = await response.json();

      if (!response.ok) {
        return;
      }

      activeSession = payload.session;
      sessionStorage.setItem('selectedLabel', activeSession.label);
      sessionStorage.setItem('selectedEmoji', activeSession.emoji);
      setStartButton(true, 'Resume Listening Session');
      sessionHint.textContent =
        activeSession.label + ' is already running. Resume it, or choose another vibe to start fresh.';
    } catch (error) {
      showMessage('The app could not check for an existing listening session.', 'error');
    }
  }

  function selectVibe(btn) {
    document.querySelectorAll('.vibe-btn').forEach(b => b.classList.remove('selected'));
    btn.classList.add('selected');
    selectedVibe = btn.dataset.label;

    sessionStorage.setItem('selectedLabel', btn.dataset.label);
    sessionStorage.setItem('selectedEmoji', btn.dataset.emoji);
    activateStartButton();
  }
  const cardColors = ['#27856A','#E91429','#DC148C','#148A08','#503750','#477D95','#E8115B','#4B6CB7'];
  const renderCustomTopics = () => {
    vibeGrid.querySelectorAll('.vibe-btn.custom-topic').forEach((node) => node.remove());
    const anchor = vibeGrid.querySelector('.create-topic-btn');
    getCustomTopics().forEach(({ label, emoji },index) => {
      const btn = document.createElement('button');
      btn.type = 'button';
      btn.className = 'vibe-btn custom-topic';
      btn.dataset.label = label;
      btn.dataset.emoji = emoji;
      btn.style.background = cardColors[index % cardColors.length];
      btn.onclick = () => selectVibe(btn);
      btn.innerHTML = `<span class="vibe-emoji">${emoji}</span><span class="vibe-label">${label}</span><div class="trash-icon" onclick="removeVibe('${label}', event)">🗑️</div>`;
      vibeGrid.insertBefore(btn, anchor);
    });
  };

  const resetModal = () => {
    topicName.value = '';
    topicEmoji.value = '';
    topicError.textContent = '';
    document.querySelectorAll('.emoji-option').forEach((el) => el.classList.remove('selected'));
  };

  const openTopicModal = () => {
    resetModal();
    topicModal.classList.add('open');
  };

  const closeTopicModal = (event) => {
    event?.preventDefault();
    topicModal.classList.remove('open');
  };

  const selectTopicEmoji = (btn) => {
    document.querySelectorAll('.emoji-option').forEach((el) => el.classList.remove('selected'));
    btn.classList.add('selected');
    topicEmoji.value = btn.textContent.trim();
  };

  const handleTopicSubmit = (event) => {
    event.preventDefault();
    const name = topicName.value.trim();
    const emoji = topicEmoji.value.trim();

    if (!name) {
      topicError.textContent = 'Please enter a topic name.';
      return;
    }
    if (name.length > 30) {
      topicError.textContent = 'Topic name must be 30 characters or fewer.';
      return;
    }
    if (!emoji) {
      topicError.textContent = 'Please choose an emoji for the topic.';
      return;
    }

    const topics = getCustomTopics();
    topics.push({ label: name, emoji });
    saveCustomTopics(topics);
    renderCustomTopics();
    closeTopicModal();

    const newBtn = Array.from(vibeGrid.querySelectorAll('.vibe-btn.custom-topic')).find(
      (btn) => btn.dataset.label === name && btn.dataset.emoji === emoji
    );
    if (newBtn) selectVibe(newBtn);
  };

  async function handleStart() {
    if (isStarting) {
      return;
    }

    if (!selectedVibe && activeSession) {
      window.location.href = '/active-session';
      return;
    }

    if (!selectedVibe) {
      return;
    }

    let forceRestart = false;
    if (activeSession && activeSession.label !== selectedVibe) {
      forceRestart = window.confirm(
        activeSession.label + ' is already running. Start a new ' + selectedVibe + ' session instead?'
      );

      if (!forceRestart) {
        return;
      }
    }

    isStarting = true;
    setStartButton(true, 'Starting Session...');

    try {
      const response = await fetch('/api/session/start', {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
        },
        body: JSON.stringify({
          label: selectedVibe,
          emoji: sessionStorage.getItem('selectedEmoji'),
          forceRestart,
        }),
      });

      if (response.status === 401) {
        window.location.href = '/login';
        return;
      }

      const payload = await response.json();

      if (!response.ok) {
        throw new Error(payload.message || 'The listening session could not be started.');
      }

      if (payload.warning) {
        showMessage(payload.warning, 'info');
      }

      window.location.href = '/active-session';
    } catch (error) {
      showMessage(error.message, 'error');
      setStartButton(true, activeSession ? 'Resume Listening Session' : 'Start Listening Session');
    } finally {
      isStarting = false;
    }
  }

  const removeVibe = (label, event) => {
    event.stopPropagation();
    const btn = event.target.closest('.vibe-btn');
    if (btn) {
      btn.style.display = 'none';
    }
    if (sessionStorage.getItem('selectedLabel') === label) {
      sessionStorage.removeItem('selectedLabel');
      sessionStorage.removeItem('selectedEmoji');
      document.querySelectorAll('.vibe-btn').forEach((item) => item.classList.remove('selected'));
      startBtn.classList.replace('active', 'inactive');
    }
    // For custom topics, remove from storage
    const customTopics = getCustomTopics();
    const filtered = customTopics.filter(topic => topic.label !== label);
    if (filtered.length !== customTopics.length) {
      saveCustomTopics(filtered);
    }
  };

  window.addEventListener('DOMContentLoaded', () => {
    renderCustomTopics();
    const storedLabel = sessionStorage.getItem('selectedLabel');
    const storedEmoji = sessionStorage.getItem('selectedEmoji');

    if (storedLabel && storedEmoji) {
      const match = Array.from(document.querySelectorAll('.vibe-btn')).find(
        (btn) => btn.dataset.label === storedLabel && btn.dataset.emoji === storedEmoji
      );
      if (match) {
        match.classList.add('selected');
        activateStartButton();
      }
    }
  });
  const name = "{{user.displayName}}";

  const messages = [
    `Welcome ${name}, let's get started 🎶`,
    `Good to see you, ${name} 👋`,
    `Ready to vibe, ${name}?`,
    `What's the mood today, ${name}?`,
    `Let's find your sound, ${name} 🎵`,
    `Time to turn it up, ${name} 🔊`,
    `What are we listening to today, ${name}?`,
    `Your daily mix is waiting, ${name} 🎧`,
    `Let the music take over, ${name} 🎼`,
    `Hit play, ${name} — the vibe awaits 🎤`,
    `New session, new sound, ${name} ✨`,
    `The aux is yours, ${name} 🎸`,
    `Drop the beat, ${name} 🥁`,
    `Curating something special for you, ${name} 🎹`,
    `Music heals everything, ${name} 💚`,
  ];

  document.querySelector('.home-subtitle').textContent = messages[Math.floor(Math.random() * messages.length)];

  loadActiveSessionState();
</script>
