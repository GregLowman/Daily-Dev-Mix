<!-- Beginning of Page Layout -->

<div class="home-wrap">
  <div class="home-inner">

    <!-- Header -->
    <div class="mb-12 fu">
      <h1 class="home-title">Daily Dev Mix</h1>
      <p class="home-subtitle"></p>
    </div>

    <!-- Vibe selector -->
    <div class="mb-12 fu d1">
      <h2 class="section-heading">Choose your vibe</h2>
      <div class="vibe-grid" id="vibeGrid">
        <button class="vibe-btn" data-label="Studying" data-emoji="📚" onclick="selectVibe(this)"><span class="vibe-emoji">📚</span><span class="vibe-label">Studying</span><div class="trash-icon" onclick="removeVibe('Studying', event)">🗑️</div></button>
        <button class="vibe-btn" data-label="Workout" data-emoji="💪" onclick="selectVibe(this)"><span class="vibe-emoji">💪</span><span class="vibe-label">Workout</span><div class="trash-icon" onclick="removeVibe('Workout', event)">🗑️</div></button>
        <button class="vibe-btn" data-label="Road Trip" data-emoji="🚗" onclick="selectVibe(this)"><span class="vibe-emoji">🚗</span><span class="vibe-label">Road Trip</span><div class="trash-icon" onclick="removeVibe('Road Trip', event)">🗑️</div></button>
        <button class="vibe-btn" data-label="Relaxing" data-emoji="🧘" onclick="selectVibe(this)"><span class="vibe-emoji">🧘</span><span class="vibe-label">Relaxing</span><div class="trash-icon" onclick="removeVibe('Relaxing', event)">🗑️</div></button>
        <button class="vibe-btn" data-label="Party" data-emoji="🎉" onclick="selectVibe(this)"><span class="vibe-emoji">🎉</span><span class="vibe-label">Party</span><div class="trash-icon" onclick="removeVibe('Party', event)">🗑️</div></button>
        <button class="vibe-btn create-topic-btn" onclick="openTopicModal()"><span class="vibe-emoji">➕</span><span class="vibe-label">Create Topic</span></button>
      </div>
    </div>

    <div id="topicModal" class="modal-backdrop" onclick="closeTopicModal(event)">
      <div class="modal-card" onclick="event.stopPropagation()">
        <div class="modal-header">
          <h3>Create New Topic</h3>
          <button class="modal-close" onclick="closeTopicModal(event)">✕</button>
        </div>
        <p class="modal-description">Add a custom listening topic and choose an emoji to represent it.</p>
        <form id="topicForm" onsubmit="handleTopicSubmit(event)">
          <label class="modal-label" for="topicName">Topic name</label>
          <input id="topicName" class="modal-input" type="text" maxlength="30" placeholder="e.g. Focus Study" autocomplete="off" />
          <p class="modal-hint">Max 30 characters</p>

          <label class="modal-label">Emoji</label>
          <div class="emoji-grid" id="emojiPicker">
            <button type="button" class="emoji-option" onclick="selectTopicEmoji(this)">🎵</button>
            <button type="button" class="emoji-option" onclick="selectTopicEmoji(this)">🎧</button>
            <button type="button" class="emoji-option" onclick="selectTopicEmoji(this)">🎸</button>
            <button type="button" class="emoji-option" onclick="selectTopicEmoji(this)">🎤</button>
            <button type="button" class="emoji-option" onclick="selectTopicEmoji(this)">🎯</button>
            <button type="button" class="emoji-option" onclick="selectTopicEmoji(this)">💬</button>
            <button type="button" class="emoji-option" onclick="selectTopicEmoji(this)">😌</button>
            <button type="button" class="emoji-option" onclick="selectTopicEmoji(this)">🚀</button>
            <button type="button" class="emoji-option" onclick="selectTopicEmoji(this)">📚</button>
          </div>
          <input id="topicEmoji" type="hidden" />
          <p id="topicError" class="modal-error"></p>

          <div class="modal-actions">
            <button type="button" class="modal-button cancel" onclick="closeTopicModal(event)">Cancel</button>
            <button type="submit" class="modal-button primary">Save Topic</button>
          </div>
        </form>
      </div>
    </div>

    <!-- Start session button -->
    <div class="mb-16 fu d2">
      <button class="start-btn inactive" id="startBtn" onclick="handleStart()">
        <!-- Play icon -->
        <svg viewBox="0 0 24 24" fill="currentColor" width="20" height="20"><path d="M8 5v14l11-7z"/></svg>
        <span class="start-btn-label" id="startBtnLabel">Start Listening Session</span>
      </button>
      <p class="session-hint" id="sessionHint">Choose a vibe to begin a live Spotify listening session.</p>
      <div class="home-message" id="homeMessage"></div>
